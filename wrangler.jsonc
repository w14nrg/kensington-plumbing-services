{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kensington-plumbing-services",
  "main": "_worker.js",
  "compatibility_date": "2026-07-22",
  "vars": {
    "OPENAI_MODEL": "gpt-5",
    "SITE_URL": "https://kensington-plumbing-services.nicholas-griffith-uk.workers.dev",
    "OWNER_EMAIL": "info@kensington.biz",
    "KEN_ADMIN_USERNAME": "nicholas",
    "NOTIFY_ALL_STAGES": "false"
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kensington-ken",
      "database_id": "c88e77cc-1ec2-4ca5-b90a-d5b938f0c615"
    }
  ]
}
