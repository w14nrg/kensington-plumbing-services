{
  "name": "kensington-plumbing-ken",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create kensington-ken",
    "db:init:local": "wrangler d1 execute kensington-ken --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute kensington-ken --remote --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
